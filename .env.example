MCP_TOASTIT_BASE_URL=https://api.toastit.cc
# Required for stdio mode. Optional for HTTP mode (clients send Authorization: Bearer <pat>).
MCP_TOASTIT_PAT=toastit_<selector>_<secret>
MCP_TOASTIT_ACCEPT=application/vnd.toastit.public+json; version=1
MCP_TOASTIT_TIMEOUT_MS=10000
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3001
MCP_RESOURCE_URI=https://mcp.toastit.cc/mcp
MCP_AUTHORIZATION_SERVER=https://toastit.cc
MCP_SCOPES_SUPPORTED=mcp:tools
